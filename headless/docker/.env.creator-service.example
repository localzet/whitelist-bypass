CREATOR_IMAGE=ghcr.io/localzet/vconnect-creator-service:latest
# Copy these IDs from client service settings.
USER_IDS=first-client-uuid,second-client-uuid
WORK_PLATFORM=telemost
# user = client cookies from encrypted vault; service = SERVICE_COOKIES from this container.
WORK_COOKIE_SOURCE=user
RESOURCES=default
MAX_ACTIVE_USERS=2
WORK_TTL=30m
# Optional override. Empty value reuses /data/service-call.txt when it exists.
# SERVICE_ROOM=https://telemost.yandex.ru/j/...
